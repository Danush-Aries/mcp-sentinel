{
  "mcpServers": {
    "weather": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-weather@1.4.2"
      ],
      "env": {
        "LOG_LEVEL": "info"
      },
      "description": "Read-only weather lookup for a city.",
      "tools": [
        {
          "name": "get_weather",
          "description": "Get the current weather for a city by name.",
          "parameters": {
            "city": {
              "type": "string",
              "description": "City name"
            }
          }
        }
      ]
    }
  }
}
